    use CommonTrait;
    public function login(Request $request)
    {
        $login    = trim((string) $request->usermailorphone);
        $password = (string) $request->password;

        if ($login === '' || $password === '') {
            return response()->json([
                'status' => 'error',
                'message' => 'UserID/Mobile and password are required!'
            ], 422);
        }

        // If it's all digits, treat as Mobile, otherwise treat as UserID (admin)
        $isMobile = ctype_digit($login);

        $credentials = [
            'password' => $password,
            'Status'   => 1,
        ];

        if ($isMobile) {
            $credentials['MobileNumber'] = $login;
        } else {
            $credentials['UserId'] = $login;
        }


        if ($token = JWTAuth::attempt($credentials)) {
            // Use the 'api' guard to get the authenticated user
            $user = auth('api')->user();
            $user->load('role'); // already authenticated by attempt()
            return $this->respondWithToken($token, $user);
        }

        return response()->json([
            'status' => 'error',
            'message' => 'Invalid User Id/Mobile or Password!'
        ], 401);
    }

