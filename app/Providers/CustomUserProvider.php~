    public function retrieveByCredentials(array $credentials)
    {
        // Remove password from credentials before querying
        $query = User::query();

        // Check if Mobile or UserID is provided
        if (isset($credentials['MobileNumber'])) {
            dd($credentials['MobileNumber']);
            $query->where('MobileNumber', $credentials['MobileNumber']);
        } elseif (isset($credentials['UserId'])) {
