//            $query->where('Status', $credentials['Status']);
//        }

        return $query->first();
    }

    public function validateCredentials(Authenticatable $user, array $credentials)
    {
        $inputPassword = $credentials['password'] ?? '';

        // Use SQL Server function to decode the stored password
        $result = DB::select("SELECT dbo.ufn_PasswordDecode(?) as DecodedPass", [$user->Password]);

        if (!empty($result)) {
            $decodedPassword = $result[0]->DecodedPass;
            // Compare the input password with the decoded password
            return $inputPassword === $decodedPassword;
        }

        return false;
    }

