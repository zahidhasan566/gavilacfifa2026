<template>
    <div class="dash" :style="{ backgroundImage: `url(${BackgroundImage})` }" >
        <!-- ✅ Banner / Hero -->
        <section class="dash-banner" :style="{ backgroundImage: `url(${HomeBannerImage})` }">
            <div class="dash-banner-overlay"></div>

            <div class="dash-banner-inner">
                <div class="dash-points">
                    <div class="dash-pill">{{ loading.points ? '...' : points.total }}</div>
                    <div class="dash-pill-label">Total Points</div>
                </div>
            </div>
        </section>

        <!-- ✅ Main content -->
        <section class="dash-content">
            <div class="dash-grid">
                <!-- Cards -->
                <div class="dash-cards">
                    <button class="dash-card" @click="go('Fixtures')">T20 World<br/>Cup Fixture</button>
                    <button class="dash-card" @click="go('Today')">Today's<br/>Match</button>
                    <button class="dash-card" @click="go('Prediction')">My<br/>Prediction</button>
                    <button class="dash-card" @click="go('Rewards')">Rewards<br/>for Winner</button>
                </div>

                <!-- Leaderboard -->
                <div class="dash-leaderboard">
                    <div class="dash-lb-title">Leaderboard</div>

                    <div v-if="loading.leaderboard" class="dash-muted">Loading...</div>

                    <div v-else class="dash-lb-list">
                        <div v-for="(u,i) in leaderboard" :key="u.id ? u.id : i" class="dash-lb-item">
                            <div class="dash-rank">{{ i + 1 }}</div>
                            <div class="dash-lb-info">
                                <div class="dash-lb-name">{{ u.name }}</div>
                                <div class="dash-lb-sub">
                                    {{ u.subtitle ? u.subtitle : ('Points: ' + formatPoints(u.points)) }}
                                </div>
                            </div>
                        </div>

                        <div v-if="!leaderboard.length" class="dash-muted">No data</div>
                    </div>
                </div>
            </div>
        </section>

    </div>
</template>

<script>
import axios from "axios";
import {baseurl} from "../../base_url";

export default {
    name: "DoctorDashboardIndex",
    data() {
        return {
            points: { total: 0 },
            // leaderboard: [],
            loading: { points: true, leaderboard: true },
            BackgroundImage:'',
            HomeBannerImage:'',
            leaderboard: [
                {
                    id: 1,
                    name: "Dr. Zahid Hasan",
                    points: 120,
                    subtitle: "Cardiology"
                },
                {
                    id: 2,
                    name: "Dr. Ayesha Khan",
                    points: 120,
                    subtitle: "Cardiology"
                },
                {
                    id: 3,
                    name: "Dr. Sana Malik",
                    points: 98,
                    subtitle: "Pediatrics"
                },
                {
                    id: 4,
                    name: "Dr. Hamza Ahmed",
                    points: 85,
                    subtitle: "Orthopedics"
                },
                {
                    id: 5,
                    name: "Dr. Noor Fatima",
                    points: 72,
                    subtitle: "General Medicine"
                }
            ]

        };
    },
    mounted() {
        this.BackgroundImage = baseurl + 'assets/images/bg/t20bg.png';
        this.HomeBannerImage = baseurl + 'assets/images/bg/HomeBanner.png';
        this.fetchPoints();
        this.fetchLeaderboard();
    },
    methods: {
        go(name) {
            this.$router.push({ name });
        },
        formatPoints(val) {
            return (val === null || val === undefined) ? "-" : val;
        },
        fetchPoints() {
            this.loading.points = true;
            axios.get("/api/user/points")
                .then(res => { this.points = res && res.data ? res.data : { total: 0 }; })
                .finally(() => { this.loading.points = false; });
        },
        fetchLeaderboard() {
            this.loading.leaderboard = true;
            axios.get("/api/leaderboard", { params: { limit: 5 } })
                .then(res => { this.leaderboard = (res && Array.isArray(res.data)) ? res.data : []; })
                .finally(() => { this.loading.leaderboard = false; });
        }
    }
};
</script>

